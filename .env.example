FOUNDEROS_WEB_HOST=127.0.0.1
FOUNDEROS_WEB_PORT=3737

# Public shell upstreams
QUORUM_API_BASE_URL=http://127.0.0.1:8800
AUTOPILOT_API_BASE_URL=http://127.0.0.1:8420/api

# Protects high-risk /api/shell/* routes in production and when explicitly set in dev.
FOUNDEROS_SHELL_ADMIN_TOKEN=change-me

# Local shell handoff store path. Production deployments should move this feature
# to a durable shared store before enabling it for real operators.
FOUNDEROS_EXECUTION_HANDOFF_STORE_PATH=.founderos-shell/execution-brief-handoffs.json
